# Leave empty to use the local `/api` path with the Vite proxy.
# If you set a full backend URL here, use the origin only (for example `http://localhost:8000`), not `/api`.
VITE_API_BASE_URL=
# Optional: override the Vite dev proxy target when VITE_API_BASE_URL is empty.
VITE_API_PROXY_TARGET=http://localhost:8000
